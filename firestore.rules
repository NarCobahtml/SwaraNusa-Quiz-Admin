rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDoc(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /quiz_modes/{docId} {
      allow read, create, update, delete: if signedIn();
    }

    match /levels/{docId} {
      allow read, create, update, delete: if signedIn();
    }

    match /questions/{docId} {
      allow read, create, update, delete: if signedIn();
    }

    match /instruments/{docId} {
      allow read, create, update, delete: if signedIn();
    }

    match /missions/{docId} {
      allow read, create, update, delete: if signedIn();
    }

    match /achievements/{docId} {
      allow read, create, update, delete: if signedIn();
    }

    match /daily_login_rewards/{docId} {
      allow read, create, update, delete: if signedIn();
    }

    match /leaderboards/{periodKey}/entries/{uid} {
      allow read: if signedIn();
      allow create, update, delete: if ownsUserDoc(uid);
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create, update: if ownsUserDoc(uid);
      allow delete: if false;

      match /level_progress/{docId} {
        allow read, create, update, delete: if ownsUserDoc(uid);
      }

      match /quiz_attempts/{attemptId} {
        allow read, create, update, delete: if ownsUserDoc(uid);

        match /answers/{answerId} {
          allow read, create, update, delete: if ownsUserDoc(uid);
        }
      }

      match /mission_progress/{docId} {
        allow read, create, update, delete: if ownsUserDoc(uid);
      }

      match /owned_instruments/{docId} {
        allow read, create, update, delete: if ownsUserDoc(uid);
      }

      match /achievements/{docId} {
        allow read, create, update, delete: if ownsUserDoc(uid);
      }

      match /daily_login/{docId} {
        allow read, create, update, delete: if ownsUserDoc(uid);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
